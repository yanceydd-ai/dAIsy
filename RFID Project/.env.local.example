# Database
# PostgreSQL connection string — local Docker: postgresql://postgres:dev@localhost:5432/postgres
# Supabase: copy from Settings → Database → URI tab
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Auth — NextAuth.js
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
NEXTAUTH_SECRET=
# NEXTAUTH_URL: base URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Azure AD — App Registration
# Requires GroupMember.Read.All Graph API permission
# App registration must be configured to include group claims in the token
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Azure AD Role Groups — Object IDs from Azure Portal → Groups
AZURE_GROUP_SAFETY_OFFICERS=
AZURE_GROUP_ACTIVITIES_COORDINATORS=
AZURE_GROUP_IT_ADMINS=
AZURE_GROUP_COMPLIANCE_OFFICERS=

# Azure IoT Hub
# Find in Azure Portal → IoT Hub → Shared access policies → service
IOTHUB_CONNECTION_STRING=

# Blackbaud SKY API
# Obtain from Blackbaud Developer Portal → My Applications
BLACKBAUD_CLIENT_ID=
BLACKBAUD_CLIENT_SECRET=
BLACKBAUD_SUBSCRIPTION_KEY=

# Azure Blob Storage
# Find in Azure Portal → Storage Account → Access keys
AZURE_BLOB_CONNECTION_STRING=
# Name of the container for export files
AZURE_BLOB_CONTAINER=rfid-exports

# Presence service configuration
# Minimum milliseconds between crossing events for the same student (default: 10000)
CLOUD_MIN_INTER_EVENT_MS=10000
